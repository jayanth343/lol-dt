{
  "name": "lol-sports-league",
  "version": "1.0.0",
  "description": "CTO DT League of Legends Sports League Management Platform",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "backfill:sport-details": "node server/backfillSportDetails.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemon": "^3.0.2",
    "socket.io": "^4.6.2"
  }
}
