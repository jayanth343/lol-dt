# ─── Server Config ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────
# Option 1: Local MongoDB (install from mongodb.com)
MONGO_URI=mongodb://localhost:27017/lol_league

# Option 2: MongoDB Atlas (cloud, free tier)
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/lol_league

# ─── JWT Secret ──────────────────────────────────────────────────
JWT_SECRET=lol_league_secret_change_in_production_2026

# ─── Client URL (for CORS) ───────────────────────────────────────
CLIENT_URL=http://localhost:3000
